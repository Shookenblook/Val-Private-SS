-- Val Key Gate GUI
local Player = game.Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")

-- Container
local GateGui = Instance.new("ScreenGui")
GateGui.Name = "ValKeyGate"
GateGui.Parent = PlayerGui

-- Main Login Frame
local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 300, 0, 180)
Frame.Position = UDim2.new(0.5, -150, 0.5, -90)
Frame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
Frame.Parent = GateGui

local Corner = Instance.new("UICorner")
Corner.CornerRadius = UDim.new(0, 10)
Corner.Parent = Frame

-- Title
local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.Text = "VAL — AUTHENTICATION"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.Font = Enum.Font.Code
Title.TextSize = 14
Title.Parent = Frame

-- Key TextBox
local KeyBox = Instance.new("TextBox")
KeyBox.Size = UDim2.new(0.8, 0, 0.25, 0)
KeyBox.Position = UDim2.new(0.1, 0, 0.35, 0)
KeyBox.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
KeyBox.TextColor3 = Color3.fromRGB(255, 255, 255)
KeyBox.PlaceholderText = "Enter Private Key..."
KeyBox.Text = ""
KeyBox.Font = Enum.Font.Code
KeyBox.Parent = Frame

Instance.new("UICorner").Parent = KeyBox

-- Submit Button
local Submit = Instance.new("TextButton")
Submit.Size = UDim2.new(0.8, 0, 0.25, 0)
Submit.Position = UDim2.new(0.1, 0, 0.65, 0)
Submit.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
Submit.TextColor3 = Color3.fromRGB(0, 0, 0)
Submit.Text = "VALIDATE"
Submit.Font = Enum.Font.SourceSansBold
Submit.Parent = Frame

Instance.new("UICorner").Parent = Submit

-- Logic to check key via Ngrok
local Remote = game.ReplicatedStorage:WaitForChild("ValRemote_v1")

Submit.MouseButton1Click:Connect(function()
    Submit.Text = "CHECKING..."
    -- We fire the remote with a special "Auth" tag
    Remote:FireServer("AUTH_CHECK", KeyBox.Text)
end)

-- Listen for success from the server
Remote.OnClientEvent:Connect(function(status)
    if status == "SUCCESS" then
        GateGui:Destroy()
        -- Trigger your main executor GUI here
        print("Val: Access Granted")
    else
        Submit.Text = "INVALID KEY"
        wait(2)
        Submit.Text = "VALIDATE"
    end
end)
